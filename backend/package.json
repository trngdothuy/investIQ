{
  "name": "investIQ-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "build": "echo \"No build step needed for JS\"",
    "start": "npm run migrate && node src/index.js",
    "lint": "oxlint src",
    "format": "oxfmt",
    "migrate": "dotenv -e .env -- node-pg-migrate up -m migrations",
    "migrate:down": "dotenv -e .env -- node-pg-migrate down -m migrations",
    "migrate:create": "node-pg-migrate create -m migrations",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "node-pg-migrate": "^8.0.4",
    "openai": "^6.46.0",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "vitest": "^4.1.8"
  }
}
